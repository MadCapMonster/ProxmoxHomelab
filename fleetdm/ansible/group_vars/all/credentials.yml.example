---
# Copy this file to:
#   ansible/group_vars/all/credentials.yml
# Then edit ONLY that file. Do not commit credentials.yml to source control.

# Linux SSH user used by Ansible. Your Ubuntu cloud VMs currently use ubuntu.
ansible_user: ubuntu
ansible_become: true

# MySQL settings used by Fleet.
fleet_mysql_root_user: root
fleet_mysql_root_password: "CHANGE_ME_MYSQL_ROOT_PASSWORD"
fleet_mysql_database: fleet
fleet_mysql_user: fleet
fleet_mysql_password: "CHANGE_ME_FLEET_MYSQL_PASSWORD"

# Redis settings used by Fleet.
# Redis typically uses the default user with requirepass unless ACLs are configured.
fleet_redis_user: default
fleet_redis_password: "CHANGE_ME_REDIS_PASSWORD_ROTATE_DISCOVERED_VALUE"

# Fleet server private key.
# Important: keep this stable across redeploys/migrations of the same Fleet instance.
fleet_server_private_key: "CHANGE_ME_FLEET_SERVER_PRIVATE_KEY"

# Optional initial/admin values for your own records or future bootstrap tasks.
# These are not currently used by the playbook unless you add Fleet bootstrap automation.
fleet_admin_email: "admin@example.com"
fleet_admin_password: "CHANGE_ME_FLEET_ADMIN_PASSWORD"
