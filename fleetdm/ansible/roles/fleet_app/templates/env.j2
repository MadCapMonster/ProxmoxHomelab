FLEET_SERVER_ADDRESS=0.0.0.0:{{ fleet_http_port }}
FLEET_SERVER_URL={{ fleet_server_url }}
FLEET_SERVER_TLS={{ fleet_tls_enabled | ternary('true', 'false') }}
FLEET_SERVER_PRIVATE_KEY={{ fleet_server_private_key }}

FLEET_MYSQL_ADDRESS={{ fleet_mysql_host }}:{{ fleet_mysql_port }}
FLEET_MYSQL_DATABASE={{ fleet_mysql_database }}
FLEET_MYSQL_USERNAME={{ fleet_mysql_user }}
FLEET_MYSQL_PASSWORD={{ fleet_mysql_password }}

FLEET_REDIS_ADDRESS={{ fleet_redis_host }}:{{ fleet_redis_port }}
FLEET_REDIS_PASSWORD={{ fleet_redis_password }}
